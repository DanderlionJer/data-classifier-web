# Copy to .env and fill in secrets. Never commit .env.
DATA_CLASSIFIER_AI_PROVIDER=deepseek
DATA_CLASSIFIER_AI_API_KEY=
# Optional: DATA_CLASSIFIER_AI_BASE_URL=https://api.deepseek.com/v1
# Optional: DATA_CLASSIFIER_AI_MODEL=deepseek-chat
# Optional: tune request size (avoid "network error" / gateway limits on huge JSON)
# DATA_CLASSIFIER_AI_BATCH_SIZE=15
# DATA_CLASSIFIER_AI_MAX_REQUEST_BYTES=98304
# DATA_CLASSIFIER_AI_MAX_COMMENT_LEN=400
# DATA_CLASSIFIER_AI_MAX_RATIONALE_LEN=380
# Optional: parallel LLM requests (faster; reduce if the API rate-limits)
# DATA_CLASSIFIER_AI_MAX_CONCURRENCY=3
